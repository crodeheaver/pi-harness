{
  "name": "pi-audited-harness",
  "version": "0.2.0",
  "description": "A small, auditable safety and workflow layer for the Pi coding agent",
  "type": "module",
  "license": "MIT",
  "keywords": [
    "pi-package",
    "pi-coding-agent",
    "coding-agent",
    "safety"
  ],
  "files": [
